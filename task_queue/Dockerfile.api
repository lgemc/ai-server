FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.115.5 \
    uvicorn[standard]==0.32.1 \
    redis==5.2.1 \
    pydantic==2.10.3

COPY task_store.py .
COPY task_api.py .
COPY vocab_api.py .

EXPOSE 8080

CMD ["uvicorn", "task_api:app", "--host", "0.0.0.0", "--port", "8080"]
