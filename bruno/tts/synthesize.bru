meta {
  name: Text to Speech
  type: http
  seq: 2
}

post {
  url: {{tts_url}}/v1/audio/speech
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "model": "tts-1",
    "input": "Hello, this is a test of the text to speech system.",
    "voice": "alloy",
    "response_format": "mp3"
  }
}
