meta {
  name: Chat Completion (Streaming)
  type: http
  seq: 4
}

post {
  url: {{vllm_url}}/v1/chat/completions
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "model": "openai/gpt-oss-120b",
    "messages": [
      {
        "role": "user",
        "content": "Write a short poem about GPUs."
      }
    ],
    "max_tokens": 256,
    "temperature": 0.7,
    "stream": true
  }
}
