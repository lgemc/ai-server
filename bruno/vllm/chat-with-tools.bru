meta {
  name: Chat with Tool Calls
  type: http
  seq: 5
}

post {
  url: {{vllm_url}}/v1/chat/completions
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "model": "openai/gpt-oss-120b",
    "messages": [
      {
        "role": "user",
        "content": "What is the weather in Tokyo?"
      }
    ],
    "tools": [
      {
        "type": "function",
        "function": {
          "name": "get_weather",
          "description": "Get current weather for a city",
          "parameters": {
            "type": "object",
            "properties": {
              "city": { "type": "string" }
            },
            "required": ["city"]
          }
        }
      }
    ],
    "tool_choice": "auto",
    "max_tokens": 512
  }
}
