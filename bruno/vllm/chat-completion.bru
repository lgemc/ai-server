meta {
  name: Chat Completion
  type: http
  seq: 3
}

post {
  url: {{vllm_url}}/v1/chat/completions
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "model": "openai/gpt-oss-120b",
    "messages": [
      {
        "role": "user",
        "content": "Hello! What can you do?"
      }
    ],
    "max_tokens": 512,
    "temperature": 0.7
  }
}
